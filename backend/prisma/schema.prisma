generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  role          Role           @default(OWNER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  passwordHash  String?
  emailVerified DateTime?
  refreshTokens RefreshToken[]
  jobs          Job[]          @relation("JobOwner")
  photos        Photo[]
  auditLogs     AuditLog[]
  notifications Notification[]
  consents      Consent[]
  owner         Owner?
  scaffolder    Scaffolder?
  engineer      Engineer?
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  OWNER
  SCAFFOLDER
  ENGINEER
}

model Owner {
  id         String     @id @default(uuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  properties Property[] @relation("PropertyOwner")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Scaffolder {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id])
  firstName         String?
  lastName          String?
  companyName       String?
  phone             String?
  isActive          Boolean            @default(true)
  jobs              JobAssignment[]
  quotes            Quote[]
  scaffolderRegions ScaffolderRegion[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ScaffolderRegion {
  id           String     @id @default(uuid())
  scaffolderId String
  regionId     String
  scaffolder   Scaffolder @relation(fields: [scaffolderId], references: [id])
  region       Region     @relation(fields: [regionId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([scaffolderId, regionId])
}

model Engineer {
  id        String       @id @default(uuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  reports   SiteReport[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Region {
  id                String             @id @default(uuid())
  name              String
  code              String             @unique
  postcode          String
  isActive          Boolean            @default(true)
  description       String?
  scaffolderRegions ScaffolderRegion[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Property {
  id           String   @id @default(uuid())
  addressLine1 String
  addressLine2 String?
  city         String
  postcode     String
  latitude     Float?
  longitude    Float?
  ownerId      String
  owner        Owner    @relation("PropertyOwner", fields: [ownerId], references: [id])
  jobs         Job[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Job {
  id                String             @id @default(uuid())
  title             String
  description       String?
  address           String
  latitude          Float?
  longitude         Float?
  status            JobStatus          @default(DRAFT)
  ownerId           String
  owner             User               @relation("JobOwner", fields: [ownerId], references: [id])
  propertyId        String?
  property          Property?          @relation(fields: [propertyId], references: [id])
  inviteToken       String?
  inviteSentAt      DateTime?
  inviteExpiresAt   DateTime?
  scheduledDate     DateTime?
  scheduledDuration Int?
  completionDate    DateTime?
  completionNotes   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assignments       JobAssignment[]
  photos            Photo[]
  quotes            Quote[]
  schedules         Schedule[]
  siteReports       SiteReport[]
  statusHistory     JobStatusHistory[]
  auditLogs         AuditLog[]
}

enum JobStatus {
  DRAFT
  AWAITING_OWNER_SUBMISSION
  SUBMITTED
  NEEDS_MORE_INFO
  VALIDATED
  ASSIGNED_TO_SCAFFOLDER
  QUOTE_PENDING
  QUOTE_SUBMITTED
  QUOTE_REVISION_REQUESTED
  QUOTE_APPROVED
  QUOTE_REJECTED
  SCHEDULING_IN_PROGRESS
  SCHEDULED
  SCAFFOLD_WORK_IN_PROGRESS
  SCAFFOLD_COMPLETE
  INSTALLER_ASSIGNED
  SITE_REPORT_PENDING
  SITE_REPORT_IN_PROGRESS
  SITE_REPORT_SUBMITTED
  COMPLETED
  CANCELLED
  ON_HOLD
}

model JobAssignment {
  id           String     @id @default(uuid())
  jobId        String
  job          Job        @relation(fields: [jobId], references: [id])
  scaffolderId String
  scaffolder   Scaffolder @relation(fields: [scaffolderId], references: [id])
  assignedBy   String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([jobId, scaffolderId])
}

model JobStatusHistory {
  id         String     @id @default(uuid())
  jobId      String
  job        Job        @relation(fields: [jobId], references: [id])
  fromStatus JobStatus?
  toStatus   JobStatus
  changedBy  String
  note       String?
  createdAt  DateTime   @default(now())
}

model Quote {
  id           String      @id @default(uuid())
  jobId        String
  job          Job         @relation(fields: [jobId], references: [id])
  scaffolderId String
  scaffolder   Scaffolder  @relation(fields: [scaffolderId], references: [id])
  amount       Float
  notes        String?
  status       QuoteStatus @default(PENDING)
  proposedDate DateTime?
  reviewedBy   String?
  reviewedAt   DateTime?
  revisionNote String?
  version      Int         @default(1)
  submittedAt  DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model Photo {
  id           String       @id @default(uuid())
  jobId        String
  job          Job          @relation(fields: [jobId], references: [id])
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  url          String
  storageKey   String
  thumbnailKey String?
  caption      String?
  reviewStatus ReviewStatus @default(PENDING)
  approved     Boolean      @default(false)
  category     PhotoCategory?
  fileName     String?
  mimeType     String?
  fileSize     Int?
  latitude     Float?
  longitude    Float?
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhotoCategory {
  ROOF
  ELECTRICAL
  PANEL_PLACEMENT
  METER
  INSTALLATION
  OTHER
}

enum ReportStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
}

model Schedule {
  id           String         @id @default(uuid())
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id])
  proposedDate DateTime
  proposedBy   String?
  duration     Int? // minutes
  status       ScheduleStatus @default(PROPOSED)
  confirmedAt  DateTime?
  confirmedBy  String?
  note         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum ScheduleStatus {
  PROPOSED
  CONFIRMED
  RESCHEDULED
  RESCHEDULE_REQUESTED
  CANCELLED
}

model SiteReport {
  id            String   @id @default(uuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  engineerId    String
  engineer      Engineer @relation(fields: [engineerId], references: [id])
  summary       String?
  findings      String?
  pdfUrl        String?
  storageKey    String?
  pdfStorageKey String?
  status        String?
  data          Json?
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
}

model Consent {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  granted   Boolean
  grantedAt DateTime  @default(now())
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AuditLog {
  id            String   @id @default(uuid())
  jobId         String?
  job           Job?     @relation(fields: [jobId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  action        String
  entityType    String
  entityId      String
  previousValue String?
  newValue      String?
  changes       Json?
  metadata      Json?
  timestamp     DateTime @default(now())
}
