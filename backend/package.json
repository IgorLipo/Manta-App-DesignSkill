{
  "name": "solar-ops-backend",
  "version": "1.0.0",
  "description": "Solar Ops API - NestJS Backend",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch prisma -- src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@nestjs/common": "^10",
    "@nestjs/config": "^3",
    "@nestjs/core": "^10",
    "@nestjs/jwt": "^10",
    "@nestjs/passport": "^10",
    "@nestjs/platform-express": "^10",
    "@nestjs/throttler": "^5",
    "@prisma/client": "^5",
    "bcryptjs": "^2",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "date-fns": "^3",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "passport-local": "^1",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "uuid": "^9"
  },
  "devDependencies": {
    "@nestjs/cli": "^10",
    "@nestjs/schematics": "^10",
    "@nestjs/testing": "^10",
    "@types/bcryptjs": "^2",
    "@types/express": "^4",
    "@types/node": "^20",
    "@types/passport-jwt": "^4",
    "@types/passport-local": "^1",
    "@types/uuid": "^9",
    "jest": "^29",
    "@types/jest": "^29",
    "prisma": "^5",
    "ts-jest": "^29",
    "ts-node": "^10",
    "ts-node-dev": "^2",
    "typescript": "^5"
  }
}
